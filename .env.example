# Скопируй этот файл в .env и заполни своими данными
# cp .env.example .env
#
# Где взять значения:
# 1. Зайди в Cloudinary → правый верх → Settings (шестерёнка) → раздел "API Keys"
# 2. Скопируй Cloud name, API Key, API Secret
# 3. Вставь сюда
#
# ⚠ .env уже в .gitignore — на GitHub он не уйдёт. Никогда не коммить его руками.

CLOUDINARY_CLOUD=твой_cloud_name_сюда
CLOUDINARY_KEY=твой_api_key_сюда
CLOUDINARY_SECRET=твой_api_secret_сюда

# Если корневая папка в Cloudinary называется не "Keira" — поменяй здесь
CLOUDINARY_ROOT_FOLDER=Keira
