# Скопируй этот файл в .env и заполни своими данными:
# cp .env.example .env
#
# Где взять Cloudinary-данные:
# 1. https://console.cloudinary.com → шестерёнка → API Keys
# 2. Скопируй Cloud name, API Key, API Secret сюда
#
# .env уже в .gitignore — на GitHub не уйдёт. Никогда не коммить руками.

CLOUDINARY_CLOUD=твой_cloud_name_сюда
CLOUDINARY_KEY=твой_api_key_сюда
CLOUDINARY_SECRET=твой_api_secret_сюда

# Корневая папка в Cloudinary
CLOUDINARY_ROOT_FOLDER=Keira

# Локальная папка с фотками — источник правды на твоём Mac
# kupload льёт оттуда в Cloudinary, kdownload скачивает в неё
# Поменяй на свой путь
LOCAL_PICTURES_ROOT=/Users/art/Pictures/Keira
